# 科大讯飞星火大模型 API 凭证
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v1.1/chat
SPARK_REST_URL=https://spark-api-open.xf-yun.com/agent/v1/chat/completions
SPARK_EMBEDDING_URL=https://emb-cn-huabei-1.xf-yun.com/

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# 数据库（默认 SQLite，生产可切 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///app.db
# DATABASE_URL=postgresql+asyncpg://ai_learning:ai_learning_2024@localhost:5432/ai_learning

REDIS_URL=redis://localhost:6379/0
CHROMA_URL=http://localhost:8001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 多模态视觉模型（拍照搜题 / 图片理解）
# 两种方案任选一种，留空则图片功能自动降级为纯文本
#
# 方案一：讯飞图片理解（WebSocket v2.1，推荐）
IMAGE_UNDERSTANDING_API_URL=wss://spark-api.cn-huabei-1.xf-yun.com/v2.1/image
IMAGE_UNDERSTANDING_API_KEY=你的APIKey
IMAGE_UNDERSTANDING_API_SECRET=你的APISecret
IMAGE_UNDERSTANDING_API_APP_ID=你的AppID
#
# 方案二：OpenAI 兼容 HTTP API（通义千问 VL / 智谱 GLM-4V / 本地 Ollama 等）
# VISION_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# VISION_API_KEY=sk-xxx
# VISION_MODEL=qwen-vl-max

# JWT 认证（生产环境务必更换为随机强密钥）
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 星火知识库 (ChatDoc)
# 基于讯飞星火文档问答 API，用于云端文档存储、向量化和精准检索
# 文档: https://www.xfyun.cn/doc/spark/ChatDoc-API.html
SPARK_KB_ENABLED=true
SPARK_KB_APP_ID=你的appId
SPARK_KB_APP_SECRET=你的appSecret
SPARK_KB_REPO_ID=
