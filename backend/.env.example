# 科大讯飞星火大模型 API 凭证
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v1.1/chat
SPARK_REST_URL=https://spark-api-open.xf-yun.com/agent/v1/chat/completions
SPARK_EMBEDDING_URL=https://emb-cn-huabei-1.xf-yun.com/

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# 数据库（默认 SQLite，生产可切 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///app.db
# DATABASE_URL=postgresql+asyncpg://ai_learning:ai_learning_2024@localhost:5432/ai_learning

REDIS_URL=redis://localhost:6379/0
CHROMA_URL=http://localhost:8001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT 认证（生产环境务必更换为随机强密钥）
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
